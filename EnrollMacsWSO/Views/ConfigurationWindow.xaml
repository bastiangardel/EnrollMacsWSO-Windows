<Window x:Class="EnrollMacsWSO.Views.ConfigurationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configuration"
        Width="817" Height="542"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Configuration de l'application" Style="{StaticResource H1}" Margin="0,0,0,20"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="FormPanel">

                <!-- Platform ID -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Platform ID :" Style="{StaticResource Label}"/>
                    <Grid Grid.Column="1">
                        <TextBox x:Name="PlatformIdBox"/>
                        <TextBlock Text="Ex: 12" IsHitTestVisible="False" Foreground="#AAAAAA"
                                   VerticalAlignment="Center" Margin="7,0,0,0" FontSize="13">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=PlatformIdBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Grid>

                <!-- Ownership -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Ownership :" Style="{StaticResource Label}"/>
                    <Grid Grid.Column="1">
                        <TextBox x:Name="OwnershipBox"/>
                        <TextBlock Text="Ex: C" IsHitTestVisible="False" Foreground="#AAAAAA"
                                   VerticalAlignment="Center" Margin="7,0,0,0" FontSize="13">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=OwnershipBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Grid>

                <!-- Message Type -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Message Type :" Style="{StaticResource Label}"/>
                    <Grid Grid.Column="1">
                        <TextBox x:Name="MessageTypeBox"/>
                        <TextBlock Text="Ex: 0" IsHitTestVisible="False" Foreground="#AAAAAA"
                                   VerticalAlignment="Center" Margin="7,0,0,0" FontSize="13">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=MessageTypeBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Grid>

                <!-- Samba Path -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Chemin SMB :" Style="{StaticResource Label}"/>
                    <Grid Grid.Column="1">
                        <TextBox x:Name="SambaPathBox"/>
                        <TextBlock Text="\\server\share\path  ou  smb://server/share/path"
                                   IsHitTestVisible="False" Foreground="#AAAAAA"
                                   VerticalAlignment="Center" Margin="7,0,0,0" FontSize="13">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=SambaPathBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Grid>

                <!-- Samba Username -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Utilisateur SMB :" Style="{StaticResource Label}"/>
                    <Grid Grid.Column="1">
                        <TextBox x:Name="SambaUsernameBox"/>
                        <TextBlock Text="Nom d'utilisateur SMB" IsHitTestVisible="False" Foreground="#AAAAAA"
                                   VerticalAlignment="Center" Margin="7,0,0,0" FontSize="13">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=SambaUsernameBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Grid>

                <!-- Samba Password -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Mot de passe SMB :" Style="{StaticResource Label}"/>
                    <PasswordBox Grid.Column="1" x:Name="SambaPasswordBox"/>
                </Grid>

                <!-- LDAP Server -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Serveur LDAP :" Style="{StaticResource Label}"/>
                    <Grid Grid.Column="1">
                        <TextBox x:Name="LdapServerBox"/>
                        <TextBlock Text="ldaps://ldap.epfl.ch" IsHitTestVisible="False" Foreground="#AAAAAA"
                                   VerticalAlignment="Center" Margin="7,0,0,0" FontSize="13">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=LdapServerBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Grid>

                <!-- LDAP Base DN -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Base DN LDAP :" Style="{StaticResource Label}"/>
                    <Grid Grid.Column="1">
                        <TextBox x:Name="LdapBaseDNBox"/>
                        <TextBlock Text="o=epfl,c=ch" IsHitTestVisible="False" Foreground="#AAAAAA"
                                   VerticalAlignment="Center" Margin="7,0,0,0" FontSize="13">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=LdapBaseDNBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Grid>

                <!-- Security note -->
                <Border Background="#EEF4FB" CornerRadius="6" Padding="12" Margin="0,10,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔒 " FontSize="14"/>
                        <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource PrimaryBrush}">
                            <Run Text="Le mot de passe SMB est chiffré via Windows DPAPI (lié à votre session Windows) et stocké dans le registre."/>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,16,0,0">
            <Button Content="💾  Enregistrer" Style="{StaticResource PrimaryButton}"
                    Margin="0,0,8,0" Click="Save_Click" x:Name="SaveBtn"/>
            <Button Content="🗑  Effacer tout" Style="{StaticResource DangerButton}"
                    Margin="0,0,8,0" Click="ClearAll_Click"/>
            <Button Content="Fermer" Click="Close_Click" Margin="0,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>
