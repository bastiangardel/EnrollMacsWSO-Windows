<Window x:Class="EnrollMacsWSO.Views.DetailsMachineWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Détails de la machine"
        Width="560" Height="580"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Window.Resources>
        <!-- Template partagé pour une ligne label / valeur -->
        <DataTemplate x:Key="InfoRowTemplate">
            <Border Background="#F5F5F5" CornerRadius="5" Margin="0,2" Padding="8,5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{Binding Label}"
                               FontWeight="SemiBold" FontSize="13"
                               TextWrapping="Wrap"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding Value}"
                               FontSize="13"
                               TextWrapping="Wrap"/>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="{StaticResource PrimaryBrush}" Padding="20,12">
            <TextBlock Text="Détails de la machine" Foreground="White" FontSize="15" FontWeight="SemiBold"/>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="16">
            <StackPanel>
                <!-- Section : Informations générales -->
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Informations générales" Style="{StaticResource H2}" Margin="0,0,0,10"/>
                        <ItemsControl x:Name="GeneralInfo"
                                      ItemTemplate="{StaticResource InfoRowTemplate}"/>
                    </StackPanel>
                </Border>

                <!-- Section : Sélections -->
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Sélections" Style="{StaticResource H2}" Margin="0,0,0,10"/>
                        <ItemsControl x:Name="SelectionInfo"
                                      ItemTemplate="{StaticResource InfoRowTemplate}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Padding="16,10"
                BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="0,1,0,0"
                Background="{StaticResource SurfaceBrush}">
            <Button Content="Fermer" Style="{StaticResource PrimaryButton}"
                    HorizontalAlignment="Center" Click="Close_Click"/>
        </Border>
    </Grid>
</Window>
