<Window x:Class="EnrollMacsWSO.Views.CredentialPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Authentification requise"
        Width="476" Height="285"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="🔐  Confirmation d'identité" Style="{StaticResource H1}" Margin="0,0,0,8"/>
        <TextBlock Grid.Row="1" Text="Veuillez entrer votre mot de passe Windows pour confirmer l'envoi des machines."
                   FontSize="13" TextWrapping="Wrap" Foreground="{StaticResource SubtleBrush}" Margin="0,0,0,16"/>

        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Utilisateur :" Style="{StaticResource Label}"/>
            <TextBox Grid.Column="1" x:Name="UsernameBox"
                     Text="{x:Static sys:Environment.UserName}"
                     xmlns:sys="clr-namespace:System;assembly=mscorlib"/>
        </Grid>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Mot de passe :" Style="{StaticResource Label}"/>
            <PasswordBox Grid.Column="1" x:Name="PasswordBox" KeyDown="Password_KeyDown"/>
        </Grid>

        <TextBlock Grid.Row="4" x:Name="ErrorText" Foreground="Red" FontSize="12"
                   Margin="0,8,0,0" Visibility="Collapsed"/>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Confirmer" Style="{StaticResource PrimaryButton}"
                    Margin="0,0,8,0" Click="Confirm_Click"/>
            <Button Content="Annuler" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
